{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowSyntheticDefaultImports": true,
    "target": "ES2021",
    "lib": ["ES2021"],
    "allowJs": true
  },
  "include": [
    "vite.config.ts",
    "src/lib/**/*.ts",
    "src/**/*.ts"
  ]
}
